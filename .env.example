# MarketView360 Admin Console - Environment Variables
# Copy this file to .env.local and fill in your values

# ===========================================
# REQUIRED - Supabase Configuration
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side only: Get from Supabase Dashboard > Settings > API > service_role key
# Required for admin operations like inviting users
# NEVER expose this in client-side code
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# REQUIRED - Backend API Configuration
# ===========================================
# This is your NestJS backend URL (NOT the admin frontend URL)
# For local development: http://localhost:4000
# For production: https://your-backend-api_url.com
NEXT_PUBLIC_API_URL=http://localhost:4000

# ===========================================
# OPTIONAL - Genesis API Configuration
# ===========================================
# If you have the Genesis service deployed, set this to its URL
# If not set, the admin console will gracefully show "unavailable" messages
# For local development: http://localhost:4000 (same as backend)
# For production: https://your-genesis-api-url.com
# NEXT_PUBLIC_GENESIS_URL=http://localhost:4000

# ===========================================
# Admin Configuration
# ===========================================
# Comma-separated list of admin email addresses allowed to access the dashboard
NEXT_PUBLIC_ADMIN_EMAIL=admin@yourdomain.com

# ===========================================
# Secrets (for Genesis API authentication)
# ===========================================
# These are used to authenticate with the Genesis API
# Set these to match your backend's configured secrets
NEXT_PUBLIC_ADMIN_SECRET=dev-admin-secret
NEXT_PUBLIC_PIPELINE_SECRET=dev-pipeline-secret
